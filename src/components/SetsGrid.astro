---
import SetCard from "./SetCard.astro";
import { sets } from "../data/sets.js";
import { bio } from "../data/bio.js";

const featured  = sets[0];
const sideSets  = sets.slice(1, 3);
---

<section id="sets" class="py-32 px-8 md:px-24 bg-background">

  <!-- Section header -->
  <div data-reveal class="flex flex-col md:flex-row justify-between items-baseline mb-20 gap-8">
    <h2 class="text-5xl md:text-8xl font-bold sonic-monolith text-white">
      Latest<br />Sets
    </h2>
    <div class="w-full md:w-1/3 h-px bg-outline-variant/30 hidden md:block"></div>
    <p class="text-on-surface-variant max-w-xs font-label text-xs uppercase tracking-[0.2em] leading-loose">
      Curated high-fidelity recordings from worldwide residencies and festival appearances.
    </p>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-10">

    {featured && (
      <!-- Featured set — col-8 -->
      <div data-reveal data-reveal-delay="1" class="md:col-span-8">
        <SetCard set={featured} featured={true} latest={true} />
      </div>
    )}

    {sideSets.map((set, i) => (
      <!-- Side sets — col-4 each -->
      <div data-reveal data-reveal-delay={String(i + 2)} class="md:col-span-4">
        <SetCard set={set} />
      </div>
    ))}

    <!-- View All -->
    <a
      href={bio.socials.youtube}
      target="_blank"
      rel="noopener noreferrer"
      class={`
        group flex items-center justify-center border border-outline-variant/30
        hover:border-secondary transition-colors p-12
        ${sideSets.length === 0 ? "md:col-span-4" : "md:col-span-8"}
      `}
    >
      <span class="text-white font-headline uppercase tracking-[0.3em] text-sm group-hover:text-secondary transition-colors">
        View All on YouTube ({sets.length})
      </span>
    </a>

  </div>
</section>

<script>
  // Click-to-play: swap YouTube thumbnail for embedded iframe on click
  document.querySelectorAll<HTMLElement>("[data-set-card]").forEach((card) => {
    const btn       = card.querySelector<HTMLButtonElement>("[data-play-btn]");
    const thumbnail = card.querySelector<HTMLElement>("[data-thumbnail]");
    const iframeSlot = card.querySelector<HTMLElement>("[data-iframe-slot]");

    btn?.addEventListener("click", () => {
      const embedUrl = btn.dataset.embed;
      if (!embedUrl || !thumbnail || !iframeSlot) return;

      iframeSlot.innerHTML = `<iframe
        src="${embedUrl}"
        class="w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>`;

      thumbnail.classList.add("hidden");
      iframeSlot.classList.remove("hidden");
    });
  });
</script>
