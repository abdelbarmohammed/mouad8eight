---
interface Props {
  gig: {
    date: string;
    venue: string;
    city: string;
    country: string;
    ticketUrl: string | null;
  };
}

const { gig } = Astro.props;

// Parse as noon local time to avoid UTC-offset day shifts
const d = new Date(`${gig.date}T12:00:00`);
const day   = String(d.getDate()).padStart(2, "0");
const month = String(d.getMonth() + 1).padStart(2, "0");
const formattedDate = `${day}.${month}`;
---

<div data-reveal class="group flex flex-col md:flex-row justify-between items-start md:items-center py-12 border-b border-outline-variant/20 hover:bg-surface-container-low transition-colors px-4">

  <!-- Left: date + venue info -->
  <div class="flex items-center gap-12 mb-4 md:mb-0">
    <span class="font-headline text-3xl md:text-5xl text-white/20 group-hover:text-secondary transition-colors leading-none">
      {formattedDate}
    </span>
    <div>
      <h4 class="text-2xl font-bold font-headline uppercase text-white">
        {gig.venue}
      </h4>
      <p class="text-on-surface-variant font-body text-xs uppercase tracking-widest">
        {gig.city}, {gig.country}
      </p>
    </div>
  </div>

  <!-- Right: ticket CTA -->
  {gig.ticketUrl ? (
    <a
      href={gig.ticketUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-headline uppercase tracking-widest py-3 px-8 border border-outline/30 hover:bg-white hover:text-black transition-all"
    >
      Tickets
    </a>
  ) : (
    <span class="text-xs font-headline uppercase tracking-widest py-3 px-8 text-white/30">
      TBA
    </span>
  )}

</div>
