---
import { gallery } from "../data/gallery.js";

type Photo = (typeof gallery)[number];

// Distribute images across 4 columns (round-robin)
const cols: Photo[][] = [[], [], [], []];
gallery.forEach((photo, i) => cols[i % 4].push(photo));

// Stagger offsets matching the Stitch masonry illusion
const colOffsets = ["", "pt-16", "", "pt-24"];
---

<section id="gallery" class="py-32 px-8 md:px-24 bg-surface-container-lowest">

  <h2 data-reveal class="text-5xl md:text-8xl font-bold sonic-monolith text-white mb-24 text-right">
    In the<br />Dark
  </h2>

  {gallery.length > 0 ? (
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {cols.map((col, colIndex) => (
        <div data-reveal data-reveal-delay={String(colIndex + 1)} class={`space-y-8 ${colOffsets[colIndex]}`}>
          {col.map((photo) => (
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full grayscale brightness-90 hover:brightness-100 transition-all duration-500"
              loading="lazy"
            />
          ))}
        </div>
      ))}
    </div>
  ) : (
    <p class="text-on-surface-variant font-body text-sm uppercase tracking-widest border-t border-outline-variant/20 pt-12">
      No photos yet — add images to public/images/ and update src/data/gallery.js.
    </p>
  )}

</section>
